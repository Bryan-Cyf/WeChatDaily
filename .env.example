# 复制为 .env 并填写（.env 已在 .gitignore，勿提交真实密钥）
#
# wx_key 输出的 64 位 hex raw_key
# 获取：微信保持登录 → 从上游下载 wx_key 并解压到 tools/wx_key/
# https://github.com/ycccccccy/wx_key/releases/tag/v2.1.8
# → 运行 tools/wx_key/wx_key.exe → 复制界面 key
WX_RAW_KEY=

# 可选：微信 db_storage 绝对路径；留空则 setup 自动检测
# WECHAT_DB_DIR=D:\Tencent\WeChat\xwechat_files\wxid_xxx\db_storage

# 可选：export 命令默认群（逗号分隔）
# WECHAT_DEFAULT_GROUPS=示例群①,示例群②

# 可选：消息显示名称
# WECHAT_SELF_WXID=
# WECHAT_SELF_NAME=我
# WECHAT_DISPLAY_NAME_MODE=remark
